{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.mccallister.guard",
  "version": "0.5.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "McCallister Guard",
    "no": "McCallister Guard"
  },
  "description": {
    "en": "Home Alone inspired smart security: psychological deterrence for intruders.",
    "no": "Alene Hjemme-inspirert smart sikkerhet: psykologisk avskrekking av tyver."
  },
  "category": [
    "security",
    "lights"
  ],
  "permissions": [
    "homey:manager:api"
  ],
  "brandColor": "#1f3a5f",
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Thomas Ekdahl",
    "email": "thomas@ekdahl.no"
  },
  "api": {
    "getStatus": {
      "method": "GET",
      "path": "/status"
    },
    "getEventLog": {
      "method": "GET",
      "path": "/events"
    },
    "getZones": {
      "method": "GET",
      "path": "/zones"
    },
    "getSettings": {
      "method": "GET",
      "path": "/settings"
    },
    "setSettings": {
      "method": "PUT",
      "path": "/settings"
    },
    "setMode": {
      "method": "POST",
      "path": "/mode"
    },
    "triggerPanic": {
      "method": "POST",
      "path": "/panic"
    },
    "testDeterrence": {
      "method": "POST",
      "path": "/test-deterrence"
    },
    "stopAlarm": {
      "method": "POST",
      "path": "/stop-alarm"
    }
  },
  "flow": {
    "triggers": [
      {
        "title": {
          "en": "Alarm escalated to CRISIS level",
          "no": "Alarm eskalert til KRISENIVÅ"
        },
        "id": "alarm_escalated"
      },
      {
        "title": {
          "en": "Alarm stopped",
          "no": "Alarm avsluttet"
        },
        "hint": {
          "en": "Fires when an active alarm is stopped (by the user, by disarming, or by deterrence completing).",
          "no": "Utløses når en aktiv alarm stoppes (av bruker, ved deaktivering, eller når avskrekking er ferdig)."
        },
        "tokens": [
          {
            "name": "zone",
            "type": "string",
            "title": {
              "en": "Zone (that triggered)",
              "no": "Sone (som utløste)"
            },
            "example": {
              "en": "Living room",
              "no": "Stua"
            }
          },
          {
            "name": "sensor",
            "type": "string",
            "title": {
              "en": "Sensor (that triggered)",
              "no": "Sensor (som utløste)"
            },
            "example": {
              "en": "Motion sensor (hallway)",
              "no": "Bevegelsessensor (gang)"
            }
          },
          {
            "name": "reason",
            "type": "string",
            "title": {
              "en": "Reason",
              "no": "Årsak"
            },
            "example": {
              "en": "User stopped alarm",
              "no": "Bruker stoppet alarm"
            }
          }
        ],
        "id": "alarm_stopped"
      },
      {
        "title": {
          "en": "Alarm triggered",
          "no": "Alarm utløst"
        },
        "hint": {
          "en": "Fires when a sensor trips the alarm while the system is armed. Use this to send notifications.",
          "no": "Utløses når en sensor aktiverer alarmen mens systemet er armert. Bruk denne til å sende varslinger."
        },
        "tokens": [
          {
            "name": "zone",
            "type": "string",
            "title": {
              "en": "Zone",
              "no": "Sone"
            },
            "example": {
              "en": "Living room",
              "no": "Stua"
            }
          },
          {
            "name": "sensor",
            "type": "string",
            "title": {
              "en": "Sensor",
              "no": "Sensor"
            },
            "example": {
              "en": "Motion sensor (hallway)",
              "no": "Bevegelsessensor (gang)"
            }
          },
          {
            "name": "sensor_type",
            "type": "string",
            "title": {
              "en": "Sensor type",
              "no": "Sensortype"
            },
            "example": {
              "en": "motion",
              "no": "bevegelse"
            }
          },
          {
            "name": "mode",
            "type": "string",
            "title": {
              "en": "Current mode",
              "no": "Aktiv modus"
            },
            "example": {
              "en": "armed_away",
              "no": "armed_away"
            }
          },
          {
            "name": "timestamp",
            "type": "string",
            "title": {
              "en": "Timestamp (ISO 8601)",
              "no": "Tidsstempel (ISO 8601)"
            },
            "example": {
              "en": "2026-05-25T19:05:42.123Z",
              "no": "2026-05-25T19:05:42.123Z"
            }
          }
        ],
        "id": "alarm_triggered"
      },
      {
        "title": {
          "en": "Deterrence started in zone",
          "no": "Avskrekking startet i sone"
        },
        "titleFormatted": {
          "en": "Deterrence started in zone [[zone]]",
          "no": "Avskrekking startet i sone [[zone]]"
        },
        "tokens": [
          {
            "name": "zone",
            "type": "string",
            "title": {
              "en": "Zone",
              "no": "Sone"
            },
            "example": {
              "en": "Master bedroom",
              "no": "Hovedsoverom"
            }
          }
        ],
        "id": "deterrence_started"
      },
      {
        "title": {
          "en": "Health check failed (offline devices)",
          "no": "Helsesjekk feilet (offline enheter)"
        },
        "tokens": [
          {
            "name": "offline_count",
            "type": "number",
            "title": {
              "en": "Offline count",
              "no": "Antall offline"
            },
            "example": 1
          }
        ],
        "id": "health_check_failed"
      },
      {
        "title": {
          "en": "Mode changed",
          "no": "Modus endret"
        },
        "hint": {
          "en": "Fires whenever the system mode changes (Hjemme / Borte / Skallsikring). Independent of alarm state.",
          "no": "Utløses hver gang systemmodus endres (Hjemme / Borte / Skallsikring). Uavhengig av alarmtilstand."
        },
        "tokens": [
          {
            "name": "mode_new",
            "type": "string",
            "title": {
              "en": "New mode",
              "no": "Ny modus"
            },
            "example": {
              "en": "armed_away",
              "no": "armed_away"
            }
          },
          {
            "name": "mode_previous",
            "type": "string",
            "title": {
              "en": "Previous mode",
              "no": "Forrige modus"
            },
            "example": {
              "en": "disarmed",
              "no": "disarmed"
            }
          }
        ],
        "id": "mode_changed"
      }
    ],
    "conditions": [
      {
        "title": {
          "en": "Alarm !{{is|is not}} active",
          "no": "Alarm !{{er|er ikke}} aktiv"
        },
        "hint": {
          "en": "True when an alarm is currently triggered (independent of mode).",
          "no": "Sann når en alarm er utløst akkurat nå (uavhengig av modus)."
        },
        "id": "alarm_active"
      },
      {
        "title": {
          "en": "Deterrence !{{is|is not}} currently active",
          "no": "Avskrekking !{{pågår|pågår ikke}} akkurat nå"
        },
        "id": "deterrence_active"
      },
      {
        "title": {
          "en": "Mode !{{is|is not}} [[mode]]",
          "no": "Modus !{{er|er ikke}} [[mode]]"
        },
        "titleFormatted": {
          "en": "Mode !{{is|is not}} [[mode]]",
          "no": "Modus !{{er|er ikke}} [[mode]]"
        },
        "args": [
          {
            "name": "mode",
            "type": "dropdown",
            "values": [
              {
                "id": "disarmed",
                "label": {
                  "en": "Home",
                  "no": "Hjemme"
                }
              },
              {
                "id": "armed_away",
                "label": {
                  "en": "Away",
                  "no": "Borte"
                }
              },
              {
                "id": "armed_stay",
                "label": {
                  "en": "Perimeter armed",
                  "no": "Skallsikring"
                }
              }
            ]
          }
        ],
        "id": "is_armed"
      }
    ],
    "actions": [
      {
        "title": {
          "en": "Set McCallister Guard mode",
          "no": "Sett McCallister Guard-modus"
        },
        "titleFormatted": {
          "en": "Set McCallister Guard mode to [[mode]]",
          "no": "Sett McCallister Guard-modus til [[mode]]"
        },
        "args": [
          {
            "name": "mode",
            "type": "dropdown",
            "values": [
              {
                "id": "disarmed",
                "label": {
                  "en": "Home (disarmed)",
                  "no": "Hjemme (deaktivert)"
                }
              },
              {
                "id": "armed_away",
                "label": {
                  "en": "Away (with exit delay)",
                  "no": "Borte (med utpassering)"
                }
              },
              {
                "id": "armed_stay",
                "label": {
                  "en": "Perimeter armed (immediate)",
                  "no": "Skallsikring (umiddelbart)"
                }
              }
            ]
          }
        ],
        "id": "set_mode"
      },
      {
        "title": {
          "en": "Trigger panic (full escalation immediately)",
          "no": "Utløs panikk (full eskalering umiddelbart)"
        },
        "id": "trigger_panic"
      }
    ]
  }
}