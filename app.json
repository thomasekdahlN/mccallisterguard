{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.homeyalone.guard",
  "version": "0.5.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Homey Alone Guard",
    "no": "Homey Alone Guard"
  },
  "description": {
    "en": "Home Alone inspired smart security: psychological deterrence for intruders.",
    "no": "Alene Hjemme-inspirert smart sikkerhet: psykologisk avskrekking av tyver."
  },
  "category": [
    "security",
    "lights"
  ],
  "permissions": [
    "homey:manager:api"
  ],
  "brandColor": "#1A531A",
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Thomas Ekdahl",
    "email": "thomas@ekdahl.no"
  },
  "contributing": {
    "donate": {
      "paypal": {
        "username": "ekdahlthomas"
      }
    }
  },
  "api": {
    "getStatus": {
      "method": "GET",
      "path": "/status"
    },
    "getEventLog": {
      "method": "GET",
      "path": "/events"
    },
    "getZones": {
      "method": "GET",
      "path": "/zones"
    },
    "getSettings": {
      "method": "GET",
      "path": "/settings"
    },
    "setSettings": {
      "method": "PUT",
      "path": "/settings"
    },
    "setMode": {
      "method": "POST",
      "path": "/mode"
    },
    "triggerPanic": {
      "method": "POST",
      "path": "/panic"
    },
    "testDeterrence": {
      "method": "POST",
      "path": "/test-deterrence"
    },
    "stopAlarm": {
      "method": "POST",
      "path": "/stop-alarm"
    }
  },
  "flow": {
    "triggers": [
      {
        "title": {
          "en": "Perimeter breach alarm stopped",
          "no": "Skallsikring-alarm avsluttet"
        },
        "hint": {
          "en": "Fires when a perimeter (armed_perimeter) breach alarm is stopped — by the user, by disarming, or automatically. Use alarm_stopped for Away (armed) mode alarms.",
          "no": "Utløses når en skallsikringsalarm (armed_perimeter) stoppes — av bruker, ved deaktivering eller automatisk. Bruk alarm_stopped for Borte-modusalarmer."
        },
        "tokens": [
          {
            "name": "zone",
            "type": "string",
            "title": {
              "en": "Zone (that triggered)",
              "no": "Sone (som utløste)"
            },
            "example": {
              "en": "Hallway",
              "no": "Gang"
            }
          },
          {
            "name": "sensor",
            "type": "string",
            "title": {
              "en": "Sensor (that triggered)",
              "no": "Sensor (som utløste)"
