{
  "id": "com.ekdahl.mccallister-guard",
  "version": "0.10.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "McCallister Guard",
    "nl": "McCallister Guard",
    "no": "McCallister Guard"
  },
  "description": {
    "en": "Home Alone inspired smart security: psychological deterrence for intruders.",
    "nl": "Op 'Home Alone' geïnspireerde slimme beveiliging: psychologische afschrikking van inbrekers.",
    "no": "Alene Hjemme-inspirert smart sikkerhet: psykologisk avskrekking av tyver."
  },
  "category": [
    "security",
    "lights"
  ],
  "permissions": [
    "homey:manager:api"
  ],
  "brandColor": "#1A531A",
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Thomas Ekdahl",
    "email": "thomas@ekdahl.no"
  },
  "contributing": {
    "donate": {
      "paypal": {
        "username": "ekdahlthomas"
      }
    }
  },
  "api": {
    "getLanguage": {
      "method": "GET",
      "path": "/language"
    },
    "getStatus": {
      "method": "GET",
      "path": "/status"
    },
    "getEventLog": {
      "method": "GET",
      "path": "/events"
    },
    "clearEventLog": {
      "method": "DELETE",
      "path": "/events"
    },
    "getZones": {
      "method": "GET",
      "path": "/zones"
    },
    "getSettings": {
      "method": "GET",
      "path": "/settings"
    },
    "setSettings": {
      "method": "PUT",
      "path": "/settings"
    },
    "setMode": {
      "method": "POST",
      "path": "/mode"
    },
    "testDeterrence": {
      "method": "POST",
      "path": "/test-deterrence"
    },
    "testAlarm": {
      "method": "POST",
      "path": "/test-alarm"
    },
    "stopAlarm": {
      "method": "POST",
      "path": "/stop-alarm"
    },
    "setCameraMotion": {
      "method": "POST",
      "path": "/set-camera-motion"
    },
    "bypassPerimeter": {
      "method": "POST",
      "path": "/bypass-perimeter"
    },
    "getSnapshotList": {
      "method": "GET",
      "path": "/snapshot-list"
    },
    "getSnapshotImage": {
      "method": "GET",
      "path": "/snapshot-image"
    },
    "deleteSnapshots": {
      "method": "DELETE",
      "path": "/snapshots"
    }
  }
}